# Copie para .env antes de rodar `docker compose up`.

# No Linux, defina como o seu UID (`id -u`) pra evitar arquivos de log
# criados como root. No Windows/Mac com Docker Desktop pode deixar o padrão.
AIRFLOW_UID=50000

# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Qualquer string secreta — usada pra assinar os tokens da API interna do Airflow 3.x.
AIRFLOW__API_AUTH__JWT_SECRET=troque-por-uma-string-aleatoria

# Login da UI do Airflow (criado automaticamente pelo airflow-init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
